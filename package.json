{
  "name": "awesome-md-to-pdf",
  "version": "0.1.0",
  "description": "Awesome editorial Markdown \u2192 PDF. Convert Markdown files in a directory to beautifully styled PDFs (Claude/Anthropic-inspired design) with mermaid, code highlighting, math, and more.",
  "bin": {
    "awesome-md-to-pdf": "bin/awesome-md-to-pdf.js",
    "md-to-pdf": "bin/md-to-pdf.js"
  },
  "main": "dist/cli.js",
  "types": "dist/cli.d.ts",
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-assets.js",
    "clean": "node scripts/clean.js",
    "rebuild": "npm run clean && npm run build",
    "prestart": "npm run build",
    "start": "node bin/md-to-pdf.js",
    "typecheck": "tsc --noEmit",
    "demo:light": "npm run build && node bin/md-to-pdf.js samples -o samples/out --toc --cover --mode light",
    "demo:dark": "npm run build && node bin/md-to-pdf.js samples -o samples/out --toc --cover --mode dark",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "markdown",
    "pdf",
    "puppeteer",
    "mermaid",
    "cli",
    "converter",
    "typescript"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "awesome-md-to-pdf contributors",
  "homepage": "https://behl1anmol.github.io/awesome-md-to-pdf",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/behl1anmol/awesome-md-to-pdf.git"
  },
  "bugs": {
    "url": "https://github.com/behl1anmol/awesome-md-to-pdf/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@vscode/markdown-it-katex": "^1.1.1",
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "chokidar": "^3.6.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "highlight.js": "^11.10.0",
    "katex": "^0.16.11",
    "markdown-it": "^13.0.2",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-container": "^3.0.0",
    "markdown-it-emoji": "^2.0.2",
    "markdown-it-footnote": "^3.0.3",
    "markdown-it-task-lists": "^2.1.1",
    "markdown-it-toc-done-right": "^4.2.0",
    "mermaid": "^10.9.1",
    "ora": "^5.4.1",
    "prompts": "^2.4.2",
    "puppeteer": "^23.9.0"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/katex": "^0.16.7",
    "@types/markdown-it": "^13.0.9",
    "@types/markdown-it-container": "^2.0.10",
    "@types/markdown-it-emoji": "^2.0.5",
    "@types/node": "^20.12.0",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.5.0"
  }
}
